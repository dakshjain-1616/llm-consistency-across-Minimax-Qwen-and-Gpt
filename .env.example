# ─────────────────────────────────────────────────────────────────────────────
# Consistency Heatmap — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# REQUIRED for live experiment runs (run_experiment.py / demo.py --live)
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ─── API Configuration ───────────────────────────────────────────────────────

# Base URL for the OpenRouter API (no trailing slash)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Referer header sent with each request (identifies your app to OpenRouter)
APP_REFERER=https://github.com/consistency-heatmap

# Title header sent with each request
APP_TITLE=Consistency Heatmap

# ─── Model Selection ─────────────────────────────────────────────────────────

# OpenRouter model ID for Qwen (latest: Qwen3.5 397B MoE flagship, February 2026)
MODEL_QWEN=qwen/qwen3.5-397b-a17b

# OpenRouter model ID for MiniMax (latest: MiniMax M2.7, 2026)
MODEL_MINIMAX=minimax/minimax-m2.7

# OpenRouter model ID for GPT (latest: GPT-5.4, March 2026)
MODEL_GPT=openai/gpt-5.4-20260305

# ─── Experiment Parameters ───────────────────────────────────────────────────

# Number of times each prompt is sent to each model (default: 10)
NUM_RUNS=10

# Number of prompts (default: 50, matches the built-in seed prompts)
NUM_PROMPTS=50

# Delay in seconds between individual API requests (rate-limit protection)
INTER_REQUEST_DELAY_SECONDS=0.5

# ─── API Request Settings ────────────────────────────────────────────────────

# HTTP request timeout in seconds
REQUEST_TIMEOUT_SECONDS=30

# Maximum tokens to generate per response
MAX_TOKENS=256

# Sampling temperature (0.0 = deterministic, 1.0 = very random)
TEMPERATURE=0.7

# Max number of retries on failed API calls
MAX_RETRIES=3

# Delay in seconds between retries (multiplied by attempt number)
RETRY_DELAY_SECONDS=2.0

# ─── Output Configuration ────────────────────────────────────────────────────

# Directory for experiment results (run_experiment.py)
RESULTS_DIR=results

# Directory for demo outputs (demo.py)
OUTPUTS_DIR=outputs

# DPI for the heatmap PNG (higher = larger file, better quality)
HEATMAP_DPI=150

# Matplotlib colormap for the heatmap (e.g. YlOrRd, Blues, viridis)
HEATMAP_COLORMAP=YlOrRd

# Figure width and height in inches
FIGURE_WIDTH=20
FIGURE_HEIGHT=5

# ─── Demo / Testing ──────────────────────────────────────────────────────────

# Random seed for mock mode (ensures reproducible demo outputs)
RANDOM_SEED=42

# ─── New in v2: Enhanced Features ────────────────────────────────────────────

# Export a flat CSV alongside JSON results (true/false — also controllable via --export-csv)
# EXPORT_CSV=false

# Generate an interactive HTML report (always on by default in demo.py)
# HTML report is written to OUTPUTS_DIR/report.html

# Cross-model divergence and semantic (Jaccard) variance are computed automatically
# and written to experiment_meta.json — no extra configuration needed.
